{
  "packet_limits": {
    "max_requirements": 12,
    "max_scenario_steps": 16,
    "max_scenarios": 3
  },
  "rewrite_static": {
    "max_batch_c_cross_attempts": 2,
    "max_command_output_bytes": 8192,
    "max_requirements_per_batch": 3,
    "max_worker_failed_checks": 3,
    "max_worker_retries": 3
  },
  "protected_paths": [
    "INSTRUCTION.md",
    "work/**",
    ".opencode/skills/**",
    "tests/**",
    "design_doc/**",
    "judge-assets/**"
  ],
  "schema_version": 1,
  "stage_order": [
    "INIT_WORKSPACE",
    "READ_C_PROJECT",
    "BUILD_C_MODEL",
    "DESIGN_RUST_API",
    "GENERATE_RUST_SCAFFOLD",
    "REWRITE_CORE_MODULES",
    "VERIFY_RUST_WITH_C_TESTS",
    "MIGRATE_TESTS",
    "BUILD_TEST_REPAIR",
    "REPORT_AND_VERIFY"
  ],
  "stages": {
    "BUILD_C_MODEL": {
      "allowed_paths": [
        "logs/trace/c_project_model.json",
        "logs/trace/c_api_model.json",
        "logs/trace/c_test_model.json"
      ],
      "required_outputs": [
        "logs/trace/c_project_model.json",
        "logs/trace/c_api_model.json",
        "logs/trace/c_test_model.json"
      ]
    },
    "BUILD_TEST_REPAIR": {
      "allowed_paths": [
        "flashDB_rust/src/**",
        "flashDB_rust/tests/**",
        "logs/trace/rust_test_mapping.json",
        "logs/trace/cargo-results.json",
        "logs/trace/cargo-build.log",
        "logs/trace/cargo-test.log",
        "logs/trace/cargo-fmt.log",
        "logs/trace/test-repair/**",
        "result/issues/repair_trace.jsonl"
      ],
      "required_outputs": [
        "logs/trace/cargo-results.json",
        "logs/trace/cargo-build.log",
        "logs/trace/cargo-test.log"
      ]
    },
    "DESIGN_RUST_API": {
      "allowed_paths": [
        "logs/trace/rust_api_design.json"
      ],
      "required_outputs": [
        "logs/trace/rust_api_design.json"
      ]
    },
    "GENERATE_RUST_SCAFFOLD": {
      "allowed_paths": [
        "flashDB_rust/**",
        "logs/trace/scaffold-manifest.json",
        "logs/trace/c-cross/**"
      ],
      "required_outputs": [
        "flashDB_rust/Cargo.toml",
        "flashDB_rust/src/lib.rs",
        "logs/trace/scaffold-manifest.json",
        "logs/trace/c-cross/scaffold-layout-check.json"
      ]
    },
    "INIT_WORKSPACE": {
      "allowed_paths": [
        "logs/interaction.md",
        "logs/trace/**",
        "result/**"
      ],
      "required_outputs": [
        "logs/trace/workflow_state.json"
      ]
    },
    "MIGRATE_TESTS": {
      "allowed_paths": [
        "flashDB_rust/tests/**",
        "logs/trace/rust_test_mapping.json",
        "logs/trace/test-placeholder-check.json",
        "logs/trace/test-consistency.json"
      ],
      "required_outputs": [
        "logs/trace/rust_test_mapping.json",
        "logs/trace/test-placeholder-check.json",
        "logs/trace/test-consistency.json"
      ]
    },
    "READ_C_PROJECT": {
      "allowed_paths": [
        "logs/trace/input_manifest.json"
      ],
      "required_outputs": [
        "logs/trace/input_manifest.json"
      ]
    },
    "REPORT_AND_VERIFY": {
      "allowed_paths": [
        "logs/trace/c-cross/**",
        "logs/trace/validation-matrix.json",
        "logs/trace/unsafe-ratio.json",
        "logs/trace/test-consistency.json",
        "logs/trace/final-manifest.json",
        "result/**"
      ],
      "required_outputs": [
        "logs/trace/validation-matrix.json",
        "logs/trace/c-cross/attempts.jsonl",
        "logs/trace/unsafe-ratio.json",
        "logs/trace/test-consistency.json",
        "logs/trace/final-manifest.json",
        "result/output.md",
        "result/issues/00-summary.md"
      ]
    },
    "REWRITE_CORE_MODULES": {
      "allowed_paths": [
        "flashDB_rust/src/**",
        "logs/trace/implementation-audit.json",
        "logs/trace/c-cross/**",
        "logs/trace/validation-matrix.json",
        "logs/trace/rewrite-c-cross/**",
        "logs/trace/rewrite-check/**",
        "logs/trace/rewrite-state.json"
      ],
      "required_outputs": [
        "logs/trace/implementation-audit.json",
        "logs/trace/rewrite-state.json"
      ]
    },
    "VERIFY_RUST_WITH_C_TESTS": {
      "allowed_paths": [
        "flashDB_rust/src/**",
        "logs/trace/c_project_model.json",
        "logs/trace/c_api_model.json",
        "logs/trace/c_test_model.json",
        "logs/trace/rust_api_design.json",
        "logs/trace/c-cross/**",
        "logs/trace/validation-matrix.json",
        "logs/trace/c-cross-state.json"
      ],
      "required_outputs": [
        "logs/trace/validation-matrix.json",
        "logs/trace/c-cross/attempts.jsonl",
        "logs/trace/c-cross/repair-plan.json"
      ]
    }
  }
}
